
{
// CIRCLES Style
"hyprland/workspaces": {
    "active-only": false,
    "all-outputs": true,
    "format": "{icon}",
    "show-special": false,
    "on-click": "activate",
    "persistent-workspaces": {
      "*": 10
    },
    "format-icons": {
        "active": "",
        "default": "",
    },
},

